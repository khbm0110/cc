# CopyTrader - Backend Environment Variables

# Server Configuration
PORT=8080
HOST=0.0.0.0

# Database Configuration
# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/copytrader?sslmode=disable

# Redis Configuration
# Redis connection for event bus and caching
REDIS_URL=redis://localhost:6379

# JWT Configuration
# Secret key for JWT token signing (min 32 chars)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=7d

# Binance API
# Your Binance API credentials (optional for testing)
BINANCE_API_KEY=your-binance-api-key
BINANCE_SECRET_KEY=your-binance-secret-key
# Use testnet for testing
BINANCE_TESTNET=true

# KMS Configuration
# Key Management Service (mock or real)
KMS_TYPE=mock
# If using AWS KMS:
# KMS_AWS_REGION=us-east-1
# KMS_AWS_KEY_ID=your-kms-key-id

# Worker Configuration
# Number of concurrent workers
WORKER_CONCURRENT_PROCESSORS=10
# Circuit breaker threshold
CIRCUIT_BREAKER_THRESHOLD=5
# Rate limit per user per minute
DEFAULT_RATE_LIMIT=60

# Reconciler Configuration
# How often to run reconciliation (in seconds)
RECONCILER_INTERVAL=300

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Metrics
# Enable Prometheus metrics
METRICS_ENABLED=true
METRICS_PORT=9090
